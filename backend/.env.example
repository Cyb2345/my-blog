DATABASE_URL=postgresql+psycopg://blog:blog_password@localhost:5432/blog
SECRET_KEY=please-change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Cloudflare R2
R2_ENABLED=true
R2_BUCKET_NAME=blog
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_PUBLIC_BASE_URL=https://img.ccby.us
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_OBJECT_PREFIX=images
MAX_UPLOAD_IMAGE_SIZE_MB=5

# Rate limiting
RATE_LIMIT_BACKEND=memory
REDIS_URL=redis://redis:6379/0
LOGIN_RATE_LIMIT_PER_MINUTE=5
LOGIN_FAILURE_LOCK_THRESHOLD=5
LOGIN_FAILURE_LOCK_MINUTES=10
CAPTCHA_RATE_LIMIT_PER_MINUTE=20
MFA_RATE_LIMIT_PER_MINUTE=10

# Optional helper values for scripts/create_admin.py.
# Do not store production passwords in source control.
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_NICKNAME=Admin
